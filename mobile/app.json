{
  "expo": {
    "name": "HT-RMT",
    "slug": "ht-rmt",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#1a1a2e"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.htrmt.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1a1a2e"
      },
      "package": "com.htrmt.app"
    },
    "plugins": [
      "expo-secure-store"
    ]
  }
}
