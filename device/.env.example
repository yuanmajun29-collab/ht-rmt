# ── 服务器连接 ──────────────────────────────────
SERVER_URL=http://192.168.1.100:3000

# ── 设备身份 ────────────────────────────────────
DEVICE_NAME=IP音柱设备-01
DEVICE_TYPE=audio-speaker
DEVICE_MODEL=HT-RMT-100
FIRMWARE_VERSION=1.0.0
# 留空则自动读取网卡 MAC
MAC_ADDRESS=
# 留空则自动生成
SERIAL_NUMBER=

# ── 网络端口 ────────────────────────────────────
# 设备自身的 HTTP 状态服务端口（平台可直连查询）
DEVICE_PORT=8080
# UDP 设备发现监听端口，需与服务器 deviceDiscovery.port 一致
DISCOVERY_PORT=5353

# ── 时间间隔（毫秒）────────────────────────────
HEARTBEAT_INTERVAL=30000
COMMAND_POLL_INTERVAL=5000
# 注册失败后重试间隔
REGISTER_RETRY_INTERVAL=10000

# ── 音频后端 ────────────────────────────────────
# 可选: sox | aplay | beep | none
# sox:  需安装 sox，命令: play -n synth <秒> sine <Hz>
# aplay: 需安装 alsa-utils，用于播放 WAV 文件
# beep: 需安装 beep，命令: beep -f <Hz> -l <毫秒>
# none: 仅打印日志，不实际播放（调试用）
AUDIO_BACKEND=sox

# ── TTS 引擎（口播文字转语音）──────────────────
# 可选: espeak | espeak-ng | none
# espeak-ng 中文: espeak-ng -v zh "文字"
TTS_ENGINE=espeak-ng

# ── 日志级别 ────────────────────────────────────
LOG_LEVEL=info
