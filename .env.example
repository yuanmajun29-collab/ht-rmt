# 平台基础配置
NODE_ENV=production
PORT=3000
INSTANCE_ID=server-1

# 集群模式启用
CLUSTER_MODE=false
CLUSTER_REDIS_URL=redis://localhost:6379

# JWT 配置
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# 数据库
DATABASE_PATH=./data/platform.db

# 设备发现配置
DEVICE_DISCOVERY_ENABLED=true
DEVICE_DISCOVERY_PORT=5353
DEVICE_DISCOVERY_INTERVAL=30000

# Redis 配置（用于分布式会话）
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379
REDIS_DB=0

# 多租户配置
MULTIENANT_ENABLED=true
DEFAULT_TENANT=default

# 本地化
LOCALE=zh_CN
LOCALES_DIR=./locales

# 日志
LOG_LEVEL=info
LOG_DIR=./logs

# 平台信息
PLATFORM_NAME=HT-RMT IP 音柱平台
PLATFORM_VERSION=0.3.0
